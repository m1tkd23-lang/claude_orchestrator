{
  "_meta": {
    "relative_path": "src/claude_orchestrator/template_assets/project_bundle/.claude_orchestrator/schemas/planner_report.schema.json"
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlannerReport",
  "type": "object",
  "required": [
    "source_task_id",
    "role",
    "cycle",
    "summary",
    "proposals"
  ],
  "properties": {
    "_meta": {
      "type": "object",
      "properties": {
        "relative_path": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "relative_path"
      ],
      "additionalProperties": true
    },
    "source_task_id": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "enum": [
        "planner_safe",
        "planner_improvement"
      ]
    },
    "cycle": {
      "type": "integer",
      "minimum": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "proposals": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": [
          "proposal_id",
          "planner_type",
          "source_task_id",
          "source_cycle",
          "title",
          "description",
          "why_now",
          "priority",
          "proposal_kind",
          "reason",
          "context_files",
          "constraints",
          "depends_on"
        ],
        "properties": {
          "proposal_id": {
            "type": "string",
            "pattern": "^proposal_[0-9]{4}$"
          },
          "planner_type": {
            "type": "string",
            "enum": [
              "safe",
              "improvement"
            ]
          },
          "source_task_id": {
            "type": "string",
            "minLength": 1
          },
          "source_cycle": {
            "type": "integer",
            "minimum": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "why_now": {
            "type": "string"
          },
          "priority": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "proposal_kind": {
            "type": "string",
            "enum": [
              "safe",
              "improvement",
              "challenge"
            ]
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "context_files": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}