# .gitignore
# ==============================
# Secrets
# ==============================
.env

# ==============================
# Python
# ==============================
__pycache__/
*.py[cod]
*.pyo
*.pyd

.venv/
venv/

# ==============================
# Build artifacts
# ==============================
dist/
build/
*.exe

# ==============================
# Logs
# ==============================
*.log
*.log.*

# ==============================
# IDE
# ==============================
.vscode/
.idea/

# ==============================
# OS junk
# ==============================
.DS_Store
Thumbs.db

# 実行時の .claude_orchestrator は除外
/.claude_orchestrator/

# ただし template_assets 配下は除外しない
!src/claude_orchestrator/template_assets/project_bundle/.claude_orchestrator/
!src/claude_orchestrator/template_assets/project_bundle/.claude_orchestrator/**


bac/
